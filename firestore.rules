rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user document
    // TEMPORARY: Allow any authenticated user to write (for testing)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: Change back to: request.auth.uid == userId
    }
    
    // Users can read and write their own profile details
    // TEMPORARY: Allow any authenticated user to write (for testing)
    match /users/{userId}/profileDetails/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: Change back
    }

    // Users can read and write their own profile details (snake_case version)
    // TEMPORARY: Allow any authenticated user to write (for testing)
    match /users/{userId}/profile_details/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: Change back
    }

    // Search index - users can read other users' search data but only write their own
    // TEMPORARY: Allow any authenticated user to write (for testing)
    match /searchIndex/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: Change back to: request.auth.uid == userId
    }

    // Conversations - users can only access conversations they're part of
    // TEMPORARY: More permissive for testing
    match /conversations/{conversationId} {
      // Allow read if user is authenticated
      allow read: if request.auth != null;
      
      // Allow create if user is authenticated and in participants
      allow create: if request.auth != null &&
                       request.resource != null &&
                       request.resource.data != null &&
                       request.auth.uid in request.resource.data.participants;
      
      // Allow update if user is authenticated (more permissive for testing)
      // TODO: Tighten to only allow if user is participant
      allow update: if request.auth != null;
      
      allow delete: if request.auth != null;

      // Messages subcollection - users can access messages in their conversations
      // TEMPORARY: More permissive for testing
      match /messages/{messageId} {
        // For reads: allow if authenticated
        allow read: if request.auth != null;
        
        // For creates: allow if user is the sender
        allow create: if request.auth != null &&
                        request.resource != null &&
                        request.resource.data != null &&
                         request.auth.uid == request.resource.data.senderId;
        
        // For updates: allow if authenticated
        // TODO: Tighten to only allow if user is sender or receiver
        allow update: if request.auth != null;
        
        allow delete: if false; // Messages cannot be deleted
      }
    }

    // Notifications - users can only access their own notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null &&
                     request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.userId;
    }

    // User interactions - users can read/write their own interactions
    match /user_interactions/{interactionId} {
      // Allow read if authenticated (queries will filter by userId field)
      allow read: if request.auth != null;
      
      // Allow create if the user is creating their own interaction
      allow create: if request.auth != null &&
                       request.resource != null &&
                       request.resource.data != null &&
                       request.auth.uid == request.resource.data.userId;
      
      // Allow update/delete if the user owns the interaction
      allow update, delete: if request.auth != null &&
                              (resource == null || 
                               resource.data == null ||
                               request.auth.uid == resource.data.userId);
    }

    // Matches - users can read matches they're part of
    match /matches/{matchId} {
      // Allow read if authenticated (queries will filter appropriately)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false; // Matches cannot be deleted
    }

    // User presence - users can read/write their own presence
    match /user_presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User stats - users can read any stats, write their own or increment others' stats
    match /user_stats/{userId} {
      allow read: if request.auth != null;
      // Allow write if user owns the stats OR if it's an increment operation (for likes received)
      allow write: if request.auth != null;
    }

    // User favorites - users can read/write their own favorites
    match /user_favorites/{favoriteId} {
      // Allow read if authenticated (queries will filter by userId field)
      allow read: if request.auth != null;
      
      // Allow create/update if the user is creating their own favorite
      allow create: if request.auth != null &&
                       request.resource != null &&
                       request.resource.data != null &&
                       request.auth.uid == request.resource.data.userId;
      
      // Allow delete if the user owns the favorite
      allow delete: if request.auth != null &&
                       (resource == null ||
                        resource.data == null ||
                        request.auth.uid == resource.data.userId);
    }

    // Daily usage tracking - users can read/write their own usage
    match /daily_usage/{docId} {
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
    }

    // Profile views - authenticated users can create, viewed user can read
    match /profile_views/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.viewerId == request.auth.uid;
      allow update: if request.auth != null &&
                       resource.data.viewerId == request.auth.uid;
    }

    // Default deny all other requests
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 